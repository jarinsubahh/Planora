<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="600.0" prefWidth="800.0" styleClass="signin-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx_project.SignInController">

    <!-- Centered card -->
    <VBox alignment="CENTER" maxHeight="595.0" maxWidth="380.0" prefHeight="595.0" prefWidth="380.0" spacing="20" styleClass="auth-card">

        <!-- Decorative icon -->
        <StackPane>
            <Circle fill="#FDF2F8" radius="24" stroke="#FF7AC6" strokeWidth="1.5" />
            <Label style="-fx-font-size: 22;" text="✨" />
        </StackPane>

        <!-- Headings -->
        <VBox alignment="CENTER" spacing="5">
            <Label styleClass="header-text" text="Welcome Back" />
            <Label styleClass="subtitle-text" text="Time to Glow and Grow" />
        </VBox>

        <!-- Back link -->
        <Button onAction="#handleBackToHome" styleClass="back-link" text="← Back to Home" />

        <!-- Input fields -->
        <VBox maxWidth="300" spacing="15">
            <VBox spacing="5">
                <Label styleClass="field-label" text="Username" />
                <TextField fx:id="usernameField" promptText="Enter your name" styleClass="auth-input" />
            </VBox>
            <VBox spacing="5">
                <Label styleClass="field-label" text="Password" />
                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="auth-input" />
            </VBox>
        </VBox>

        <!-- Sign In button -->
        <Button fx:id="signInSubmitBtn" maxWidth="300" onAction="#onLoginButtonClick" styleClass="btn-gradient" text="Sign In ✨" />

        <!-- Sign Up link -->
        <HBox alignment="CENTER" spacing="5">
            <Label style="-fx-text-fill: #6B7280;" text="New here?" />
            <Hyperlink onAction="#goToSignUp" style="-fx-text-fill: #FF7AC6; -fx-font-weight: 800; -fx-underline: false;" text="Create an Account" />
        </HBox>

        <!-- Social buttons -->
        <HBox alignment="CENTER" maxWidth="300" spacing="10" />
    </VBox>
</StackPane>

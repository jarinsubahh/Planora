<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0" stylesheets="@features-view.css" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx_project.FeaturesController">
   <children>
      <VBox layoutX="0.0" layoutY="0.0" prefHeight="600.0" prefWidth="1000.0" spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Hero Section -->
            <VBox prefHeight="140.0" prefWidth="1000.0" spacing="12.0" styleClass="hero-section">
               <padding>
                  <Insets bottom="20.0" left="50.0" right="50.0" top="30.0" />
               </padding>
               <children>
                  <!-- Top Navigation with Back Button -->
                  <HBox prefHeight="30.0" prefWidth="900.0">
                     <children>
                        <Button fx:id="backButton" minWidth="80.0" mnemonicParsing="false" onAction="#handleBackButton" prefHeight="30.0" styleClass="back-button" text="← Back" />
                     </children>
                  </HBox>
                  
                  <!-- Hero Title -->
                  <Label fx:id="heroTitle" styleClass="hero-title" text="Everything You Need to Stay on Track" wrapText="true" />
                  
                  <!-- Hero Subtitle -->
                  <Label fx:id="heroSubtitle" styleClass="hero-subtitle" text="Powerful features wrapped in a peaceful interface." wrapText="true" />
               </children>
            </VBox>

            <!-- Feature Cards Grid Section -->
            <VBox prefHeight="460.0" prefWidth="1000.0" spacing="0.0" styleClass="cards-section">
               <padding>
                  <Insets bottom="30.0" left="50.0" right="50.0" top="20.0" />
               </padding>
               <children>
                  <!-- 2x3 Grid of Feature Cards -->
                  <GridPane gridLinesVisible="false" hgap="25.0" prefHeight="410.0" prefWidth="900.0" vgap="25.0">
                     <columnConstraints>
                        <javafx.scene.layout.ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <javafx.scene.layout.ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <javafx.scene.layout.ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <javafx.scene.layout.RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <javafx.scene.layout.RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <!-- Card 1: Smart Dashboard -->
                        <VBox fx:id="card1" prefHeight="180.0" prefWidth="250.0" styleClass="feature-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                           <children>
                              <Label styleClass="card-icon" text="🧭" />
                              <Label styleClass="card-title" text="Smart Dashboard" />
                              <Label styleClass="card-description" text="See all your tasks at a glance with organized task cards and smart categorization." wrapText="true" />
                           </children>
                        </VBox>

                        <!-- Card 2: Task Prioritization -->
                        <VBox fx:id="card2" prefHeight="180.0" prefWidth="250.0" styleClass="feature-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                           <children>
                              <Label styleClass="card-icon" text="📌" />
                              <Label styleClass="card-title" text="Task Prioritization" />
                              <Label styleClass="card-description" text="Set priority levels and focus on what truly matters with urgency-based sorting." wrapText="true" />
                           </children>
                        </VBox>

                        <!-- Card 3: Calendar View -->
                        <VBox fx:id="card3" prefHeight="180.0" prefWidth="250.0" styleClass="feature-card" GridPane.columnIndex="2" GridPane.rowIndex="0">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                           <children>
                              <Label styleClass="card-icon" text="📅" />
                              <Label styleClass="card-title" text="Calendar View" />
                              <Label styleClass="card-description" text="Plan visually with an integrated calendar that maps your tasks by date." wrapText="true" />
                           </children>
                        </VBox>

                        <!-- Card 4: Focus Mode -->
                        <VBox fx:id="card4" prefHeight="180.0" prefWidth="250.0" styleClass="feature-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                           <children>
                              <Label styleClass="card-icon" text="🎯" />
                              <Label styleClass="card-title" text="Focus Mode" />
                              <Label styleClass="card-description" text="Stay distraction-free with calming modes like Night, Rain, and Nature." wrapText="true" />
                           </children>
                        </VBox>

                        <!-- Card 5: Collaborative Spaces -->
                        <VBox fx:id="card5" prefHeight="180.0" prefWidth="250.0" styleClass="feature-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                           <children>
                              <Label styleClass="card-icon" text="🚀" />
                              <Label styleClass="card-title" text="Collaborative Spaces" />
                              <Label styleClass="card-description" text="Work together by creating shared spaces for tasks, ideas, and teamwork." wrapText="true" />
                           </children>
                        </VBox>

                        <!-- Card 6: Real-time Chat -->
                        <VBox fx:id="card6" prefHeight="180.0" prefWidth="250.0" styleClass="feature-card" GridPane.columnIndex="2" GridPane.rowIndex="1">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                           <children>
                              <Label styleClass="card-icon" text="💬" />
                              <Label styleClass="card-title" text="Real-time Chat" />
                              <Label styleClass="card-description" text="Communicate instantly with your team inside each collaborative space." wrapText="true" />
                           </children>
                        </VBox>
                     </children>
                  </GridPane>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>

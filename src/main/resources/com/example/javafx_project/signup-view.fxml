<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="700.0" prefWidth="1200.0" styleClass="auth-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx_project.SignUpController">

    <!-- Centered card -->
    <VBox alignment="CENTER" maxHeight="600.0" maxWidth="380" prefHeight="600.0" prefWidth="297.0" spacing="20" styleClass="auth-card">

        <!-- Headings -->
        <VBox alignment="CENTER" prefHeight="86.0" prefWidth="261.0" spacing="5" />
         <Label prefHeight="57.0" prefWidth="164.0" styleClass="header-text" text="Plan Smart">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
         <Label style="-fx-font-size: 24; -fx-font-weight: 800; -fx-text-fill: #6EC1FF;" text="Glow Bright" />
         <Label styleClass="subtitle-text" text="Start your journey with Planora" />

        <!-- Input fields -->
        <VBox maxWidth="300" spacing="15">
            <VBox spacing="5">
                <Label styleClass="field-label" text="Username" />
                <TextField fx:id="usernameField" promptText="Choose a username" styleClass="auth-input" />
            </VBox>
            <VBox spacing="5">
                <Label styleClass="field-label" text="Email" />
                <TextField fx:id="emailField" promptText="you@example.com" styleClass="auth-input" />
            </VBox>
            <VBox spacing="5">
                <Label styleClass="field-label" text="Password" />
                <PasswordField fx:id="passwordField" promptText="Create password" styleClass="auth-input" />
            </VBox>
            <VBox spacing="5">
                <Label styleClass="field-label" text="Confirm" />
                <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" styleClass="auth-input" />
            </VBox>
        </VBox>

        <!-- Sign Up button -->
        <Button maxWidth="300" onAction="#handleSignUp" styleClass="btn-gradient" text="Get Started ✨" />

        <!-- Sign In link -->
        <Hyperlink onAction="#goToSignIn" styleClass="back-link" text="Already have an account? Sign In" />

        <!-- Error label -->
        <Label fx:id="errorLabel" styleClass="error-text" visible="false" />
    </VBox>
</StackPane>

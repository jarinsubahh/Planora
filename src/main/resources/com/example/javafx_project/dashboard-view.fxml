<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" styleClass="dashboard-root" stylesheets="@dashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx_project.DashboardController">
   <left>
      <VBox prefHeight="700.0" prefWidth="180.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="logo" text="✨ PLANORA" />
            <Button fx:id="dashboardBtn" onAction="#handleDashboard" styleClass="sidebar-button, sidebar-button-active" text="🏠 Dashboard" />
            <Button fx:id="todayBtn" onAction="#handleToday" styleClass="sidebar-button" text="📅 Today" />
            <Button fx:id="upcomingBtn" onAction="#handleUpcoming" styleClass="sidebar-button" text="⏰ Upcoming" />
            <Button fx:id="completedBtn" onAction="#handleCompleted" styleClass="sidebar-button" text="✅ Completed" />
            <Button fx:id="focusBtn" onAction="#handleFocusMode" styleClass="sidebar-button" text="🎯 Focus Mode" />
            <Button fx:id="calendarBtn" onAction="#handleCalendar" styleClass="sidebar-button" text="📆 Calendar" />
            <Button fx:id="spaceBtn" onAction="#handleSpace" styleClass="sidebar-button" text="👤Space" />
            <Button fx:id="settingsBtn" onAction="#handleNavigateToSettings" styleClass="sidebar-button" text="⚙ Settings" />
            <Button onAction="#handleLogout" styleClass="sidebar-button" text=" 🚪 Logout" />
         </children>
      </VBox>
   </left>
   <center>
      <VBox fx:id="mainContent" spacing="15.0" styleClass="center-content" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="header">
               <children>
                  <VBox>
                     <children>
                        <Label fx:id="greeting" styleClass="greeting" text="" />
                        <Label fx:id="headerDateLabel" styleClass="date" text="" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <StackPane prefHeight="61.0" prefWidth="135.0">
                     <children>
                        <Circle fx:id="progressCircle" fill="transparent" radius="27.5" stroke="#7A73FF" strokeWidth="6.0" />
                        <Label fx:id="progressPercentageLabel" styleClass="progress-text" text="0%" />
                     </children>
                  </StackPane>
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <children>
                        <Button onAction="#handleAddTask" styleClass="add-task-button" text="+ Add Task" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="80.0" styleClass="stats-row">
               <children>
                  <VBox alignment="CENTER" prefHeight="89.0" prefWidth="191.0" spacing="10.0" styleClass="stats-card">
                     <children>
                        <Label styleClass="stats-icon" text="📅" />
                        <Label fx:id="todayStatsLabel" styleClass="stats-number" text="0" />
                        <Label styleClass="stats-label" text="Today" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="89.0" prefWidth="103.0" spacing="10.0" styleClass="stats-card">
                     <children>
                        <Label styleClass="stats-icon" text="⏰" />
                        <Label fx:id="upcomingStatsLabel" styleClass="stats-number" text="0" />
                        <Label styleClass="stats-label" text="Upcoming" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="89.0" prefWidth="221.0" spacing="10.0" styleClass="stats-card">
                     <children>
                        <Label styleClass="stats-icon" text="🔥" />
                        <Label fx:id="streakStatsLabel" styleClass="stats-number" text="1" />
                        <Label styleClass="stats-label" text="Streak" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefHeight="89.0" prefWidth="116.0" spacing="10.0" styleClass="stats-card">
                     <children>
                        <Label styleClass="stats-icon" text="📈" />
                        <Label fx:id="totalStatsLabel" styleClass="stats-number" text="0" />
                        <Label styleClass="stats-label" text="Total" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <HBox spacing="20.0">
               <children>
                  <VBox maxWidth="815.0" minHeight="440.0" prefHeight="330.0" prefWidth="815.0" spacing="10.0" styleClass="task-container" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="taskSectionTitleLabel" styleClass="task-title" text="✿ Today's Tasks" />
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="357.0" prefWidth="783.0" stylesheets="@dashboard.css" vbarPolicy="ALWAYS">
                           <content>
                              <VBox fx:id="taskListVBox" spacing="10.0" />
                           </content>
                        </ScrollPane>
                     </children>
                  </VBox>
                  <VBox fx:id="filterPanel" spacing="12.0" styleClass="filter-panel">
                     <children>
                        <Label styleClass="filter-title" text="🏷 Category" />
                        <Button fx:id="filterAllBtn" onAction="#handleFilterCategory" styleClass="category-filter-button, category-filter-selected" text="All" />
                        <Button fx:id="filterStudyBtn" onAction="#handleFilterCategory" styleClass="category-filter-button" text="📚 Study" />
                        <Button fx:id="filterWorkBtn" onAction="#handleFilterCategory" styleClass="category-filter-button" text="💼 Work" />
                        <Button fx:id="filterPersonalBtn" onAction="#handleFilterCategory" styleClass="category-filter-button" text="💝 Personal" />
                        <Button fx:id="filterHealthBtn" onAction="#handleFilterCategory" styleClass="category-filter-button" text="💪 Health" />
                        <Button fx:id="filterOtherBtn" onAction="#handleFilterCategory" styleClass="category-filter-button" text="🎯 Other" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>

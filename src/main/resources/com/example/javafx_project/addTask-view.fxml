<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="900.0" spacing="20.0" styleClass="modal-background" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafx_project.AddTaskController">
   <!-- Header -->
   <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="header">
      <Button fx:id="backButton" onAction="#goBackToDashboard" styleClass="back-button" text="← Back" />
      <Label styleClass="header-title" text="Add New Task" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="closeButton" onAction="#closeWindow" styleClass="close-button" text="✕" />
   </HBox>

   <!-- Title Field -->
   <VBox spacing="5.0">
      <Label styleClass="field-label" text="Title" />
      <TextField fx:id="titleField" promptText="What needs to be done?" styleClass="input-field" />
   </VBox>

   <!-- Description Field -->
   <VBox spacing="5.0">
      <Label styleClass="field-label" text="Description" />
      <TextArea fx:id="descriptionArea" promptText="Add details..." styleClass="input-field" />
   </VBox>

   <!-- Deadline and Category Row -->
   <HBox spacing="30.0">
      <VBox spacing="5.0">
         <Label styleClass="field-label" text="Deadline" />
         <DatePicker fx:id="deadlinePicker" styleClass="input-field" />
      </VBox>
      <VBox spacing="5.0">
         <Label styleClass="field-label" text="Category" />
         <ComboBox fx:id="categoryComboBox" prefWidth="160.0" promptText="Select category" styleClass="input-field" />
      </VBox>
   </HBox>

   <!-- Priority Section -->
   <VBox spacing="10.0">
      <Label styleClass="field-label" text="Priority" />
      <HBox spacing="15.0">
         <Button fx:id="lowButton" onAction="#selectPriority" styleClass="priority-button" text="Low" />
         <Button fx:id="mediumButton" onAction="#selectPriority" styleClass="priority-button" text="Medium" />
         <Button fx:id="highButton" onAction="#selectPriority" styleClass="priority-button" text="High" />
         <Button fx:id="urgentButton" onAction="#selectPriority" styleClass="priority-button" text="Urgent" />
      </HBox>
   </VBox>

   <!-- Save Button -->
   <Button fx:id="saveButton" onAction="#saveTask" styleClass="save-task-button" text="Save Task" />
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
</VBox>
